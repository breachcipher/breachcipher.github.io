#!/bin/bash
# mkinitramfs for LFS Live ISO
# Compatible: Ventoy, Rufus, USB, CD/DVD

copy()
{
  local file

  if [ "$2" = "lib" ]; then
    file=$(PATH=/usr/lib type -p $1 2>/dev/null)
  else
    file=$(type -p $1 2>/dev/null)
  fi

  if [ -n "$file" ] ; then
    cp "$file" "$WDIR/usr/$2"
  else
    echo "Warning: Missing file: $1"
  fi
}

if [ -z "$1" ] ; then
  INITRAMFS_FILE=initrd.img-no-kmods
else
  KERNEL_VERSION=$1
  INITRAMFS_FILE=initrd.img-$KERNEL_VERSION
fi

if [ -n "$KERNEL_VERSION" ] && [ ! -d "/lib/modules/$1" ] ; then
  echo "ERROR: No modules directory: /lib/modules/$1"
  exit 1
fi

printf "Creating $INITRAMFS_FILE... "

# Binaries wajib ada di initramfs
binfiles="sh bash cat cp dd killall ls mkdir mknod mount lsblk grep mountpoint blkid"
binfiles="$binfiles umount sed sleep ln rm uname readlink basename"
binfiles="$binfiles chmod chown find"

# udevadm
if [ -x /usr/bin/udevadm ] ; then binfiles="$binfiles udevadm"
elif [ -x /sbin/udevadm ] ; then binfiles="$binfiles udevadm"
fi

sbinfiles="modprobe blkid switch_root"

# udevd — cari di semua lokasi
for f in udevd udevadm; do
  if   [ -x /usr/sbin/$f ] ; then sbinfiles="$sbinfiles $f"
  elif [ -x /sbin/$f ]     ; then sbinfiles="$sbinfiles $f"
  fi
done

unsorted=$(mktemp /tmp/unsorted.XXXXXXXXXX)

DATADIR=/usr/share/mkinitramfs
INITIN=init.in

WDIR=$(mktemp -d /tmp/initrd-work.XXXXXXXXXX)

# Buat struktur direktori lengkap
mkdir -p $WDIR/{dev,run,sys,proc,tmp,tmpmnt,usr/{bin,lib/{firmware,modules},sbin}}
mkdir -p $WDIR/{mnt,squash,cow/{mod,buffer},.root}
mkdir -p $WDIR/etc/{modprobe.d,udev/rules.d}

touch $WDIR/etc/modprobe.d/modprobe.conf

# Symlinks standar
ln -s usr/bin  $WDIR/bin
ln -s usr/lib  $WDIR/lib
ln -s usr/sbin $WDIR/sbin
ln -s lib      $WDIR/lib64

# Device nodes minimal
mknod -m 640 $WDIR/dev/console c 5 1
mknod -m 664 $WDIR/dev/null    c 1 3
mknod -m 640 $WDIR/dev/kmsg    c 1 11
# Loop devices (dibutuhkan untuk mount squashfs)
for i in 0 1 2 3 4 5 6 7; do
  mknod -m 660 $WDIR/dev/loop$i b 7 $i
done

# udev config
if [ -f /etc/udev/udev.conf ]; then
  cp /etc/udev/udev.conf $WDIR/etc/udev/udev.conf
fi

# udev rules
if [ -d /etc/udev/rules.d ]; then
  for file in /etc/udev/rules.d/*.rules; do
    [ -f "$file" ] && cp "$file" "$WDIR/etc/udev/rules.d/"
  done
fi

# Firmware (optional)
if [ -d /lib/firmware ]; then
  cp -a /lib/firmware $WDIR/usr/lib/ 2>/dev/null || true
fi

# Install init script
install -m0755 $DATADIR/$INITIN $WDIR/init

# Tambahkan kmod tools jika tersedia
if [ -n "$KERNEL_VERSION" ] ; then
  if [ -x /usr/bin/kmod ] ; then
    binfiles="$binfiles kmod"
  else
    binfiles="$binfiles lsmod"
    sbinfiles="$sbinfiles insmod"
  fi
fi

# Install binaries dari /usr/bin atau /bin
for f in $binfiles ; do
  if [ -x /usr/bin/$f ]; then
    ldd /usr/bin/$f 2>/dev/null | sed "s/\t//" | cut -d " " -f1 >> $unsorted
    copy $f bin
  elif [ -x /bin/$f ]; then
    ldd /bin/$f 2>/dev/null | sed "s/\t//" | cut -d " " -f1 >> $unsorted
    copy $f bin
  else
    echo "Warning: $f not found in /usr/bin or /bin"
  fi
done

# Install sbinaries dari /usr/sbin atau /sbin
for f in $sbinfiles ; do
  if [ -x /usr/sbin/$f ]; then
    ldd /usr/sbin/$f 2>/dev/null | sed "s/\t//" | cut -d " " -f1 >> $unsorted
    copy $f sbin
  elif [ -x /sbin/$f ]; then
    ldd /sbin/$f 2>/dev/null | sed "s/\t//" | cut -d " " -f1 >> $unsorted
    copy $f sbin
  else
    echo "Warning: $f not found in /usr/sbin or /sbin"
  fi
done

# Cari dan copy udevd dari semua lokasi
UDEVD_FOUND=0
for udevd_path in \
  /usr/lib/udev/udevd \
  /lib/udev/udevd \
  /usr/lib/systemd/systemd-udevd \
  /usr/sbin/udevd \
  /sbin/udevd
do
  if [ -x "$udevd_path" ]; then
    ldd "$udevd_path" 2>/dev/null | sed "s/\t//" | cut -d " " -f1 >> $unsorted
    # Tentukan target path
    case "$udevd_path" in
      /usr/lib/udev/*)        dest="$WDIR/usr/lib/udev/" ;;
      /lib/udev/*)            dest="$WDIR/usr/lib/udev/" ;;
      /usr/lib/systemd/*)     mkdir -p "$WDIR/usr/lib/systemd"; dest="$WDIR/usr/lib/systemd/" ;;
      *)                      dest="$WDIR/usr/sbin/" ;;
    esac
    mkdir -p "$dest"
    cp "$udevd_path" "$dest"
    echo "Copied udevd from $udevd_path"
    UDEVD_FOUND=1
    break
  fi
done
[ $UDEVD_FOUND -eq 0 ] && echo "WARNING: udevd not found anywhere! udev will not work."

# kmod symlinks
if [ -n "$KERNEL_VERSION" ] && [ -x /usr/bin/kmod ] ; then
  ln -sf kmod $WDIR/usr/bin/lsmod
  ln -sf kmod $WDIR/usr/bin/insmod
  ln -sf kmod $WDIR/usr/bin/modinfo
fi

# Install shared libraries
sort $unsorted | uniq | while read library ; do
  case "$library" in
    linux-vdso.so*)     continue ;;
    linux-gate.so*)     continue ;;
    libsystemd-shared*) continue ;;
  esac

  # Cari library di berbagai lokasi
  lib_file=""
  for libdir in /usr/lib /lib /usr/lib/x86_64-linux-gnu /lib/x86_64-linux-gnu; do
    if [ -f "$libdir/$library" ]; then
      lib_file="$libdir/$library"
      break
    fi
  done

  if [ -n "$lib_file" ]; then
    cp "$lib_file" "$WDIR/usr/lib/" 2>/dev/null || true
  else
    copy $library lib
  fi
done

# Copy direktori udev lengkap (rules, helpers, dll)
for udev_dir in /usr/lib/udev /lib/udev; do
  if [ -d "$udev_dir" ]; then
    cp -a "$udev_dir" $WDIR/usr/lib/ 2>/dev/null || true
    echo "Copied udev directory from $udev_dir"
  fi
done

# Install kernel modules
if [ -n "$KERNEL_VERSION" ]; then
  echo "Including modules for $KERNEL_VERSION..."

  # Daftar modul paths — tambah paths untuk Ventoy/USB
  for modpath in \
    /lib/modules/$KERNEL_VERSION/kernel/crypto \
    /lib/modules/$KERNEL_VERSION/kernel/fs \
    /lib/modules/$KERNEL_VERSION/kernel/lib \
    /lib/modules/$KERNEL_VERSION/kernel/drivers/block \
    /lib/modules/$KERNEL_VERSION/kernel/drivers/md \
    /lib/modules/$KERNEL_VERSION/kernel/drivers/cdrom \
    /lib/modules/$KERNEL_VERSION/kernel/drivers/gpu \
    /lib/modules/$KERNEL_VERSION/kernel/drivers/video \
    /lib/modules/$KERNEL_VERSION/kernel/drivers/scsi \
    /lib/modules/$KERNEL_VERSION/kernel/drivers/net \
    /lib/modules/$KERNEL_VERSION/kernel/drivers/virtio \
    /lib/modules/$KERNEL_VERSION/kernel/drivers/usb/host \
    /lib/modules/$KERNEL_VERSION/kernel/drivers/usb/storage \
    /lib/modules/$KERNEL_VERSION/kernel/drivers/net/wireless \
    /lib/modules/$KERNEL_VERSION/kernel/net/wireless
  do
    [ -d "$modpath" ] && find "$modpath" -type f 2>/dev/null | cpio --make-directories -p --quiet $WDIR
  done

  # Copy module metadata
  mkdir -p $WDIR/usr/lib/modules/$KERNEL_VERSION
  for f in modules.builtin modules.order modules.builtin.modinfo; do
    [ -f /lib/modules/$KERNEL_VERSION/$f ] && \
      cp /lib/modules/$KERNEL_VERSION/$f $WDIR/usr/lib/modules/$KERNEL_VERSION/ 2>/dev/null || true
  done

  # Juga copy ke /lib/modules (beberapa modprobe carinya di sini)
  mkdir -p $WDIR/lib/modules/$KERNEL_VERSION
  for f in modules.builtin modules.order modules.builtin.modinfo; do
    [ -f /lib/modules/$KERNEL_VERSION/$f ] && \
      cp /lib/modules/$KERNEL_VERSION/$f $WDIR/lib/modules/$KERNEL_VERSION/ 2>/dev/null || true
  done

  depmod -b $WDIR $KERNEL_VERSION
fi

# Create initramfs
( cd $WDIR ; find . | cpio -o -H newc --quiet | gzip -9 ) > $INITRAMFS_FILE

# Tampilkan ukuran
SIZE=$(du -sh $INITRAMFS_FILE | cut -f1)
echo "done. (size: $SIZE)"

# Verifikasi binary penting
echo ""
echo "=== Verifying critical binaries ==="
for f in init usr/bin/sh usr/sbin/switch_root usr/sbin/modprobe usr/bin/mount usr/bin/lsblk; do
  if [ -f "$WDIR/$f" ] || [ -L "$WDIR/$f" ]; then
    echo "  OK: /$f"
  else
    echo "  MISSING: /$f  <-- WARNING!"
  fi
done

# Cleanup
rm -rf $WDIR $unsorted
