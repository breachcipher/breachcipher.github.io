#!/bin/bash
# mkinitramfs for LFS Live ISO
# Compatible: Ventoy, Rufus, USB, CD/DVD

# ===================== FUNCTIONS =====================

copy()
{
  local file

  if [ "$2" = "lib" ]; then
    file=$(PATH=/usr/lib type -p $1 2>/dev/null)
  else
    file=$(type -p $1 2>/dev/null)
  fi

  if [ -n "$file" ] ; then
    cp "$file" "$WDIR/usr/$2"
    echo "  Copied: $1 -> $WDIR/usr/$2"
  else
    echo "Warning: Missing file: $1"
  fi
}

copy_with_deps()
{
  local src_file="$1"
  local dest_dir="$2"
  
  if [ -f "$src_file" ] && [ ! -f "$WDIR/$dest_dir/$(basename $src_file)" ]; then
    cp "$src_file" "$WDIR/$dest_dir/"
    echo "  Copied: $src_file -> $WDIR/$dest_dir/"
    
    # Copy dependencies
    ldd "$src_file" 2>/dev/null | while read line; do
      case "$line" in
        *"=>"*)
          lib=$(echo "$line" | sed 's/.*=> //' | sed 's/ (0x.*//')
          if [ -f "$lib" ]; then
            cp "$lib" "$WDIR/usr/lib/" 2>/dev/null || true
          fi
          ;;
        *"not found"*)
          echo "  WARNING: Library not found for $src_file"
          ;;
      esac
    done
  fi
}

# ===================== MAIN =====================

# Parse arguments
if [ -z "$1" ] ; then
  INITRAMFS_FILE="initrd.img-no-kmods"
  KERNEL_VERSION=""
else
  KERNEL_VERSION="$1"
  INITRAMFS_FILE="initrd.img-$KERNEL_VERSION"
fi

if [ -n "$KERNEL_VERSION" ] && [ ! -d "/lib/modules/$KERNEL_VERSION" ] ; then
  echo "ERROR: No modules directory: /lib/modules/$KERNEL_VERSION"
  exit 1
fi

printf "Creating $INITRAMFS_FILE... "

# ===================== BINARY LIST =====================

# Binaries wajib ada di initramfs (tanpa head/awk/sed yang tidak perlu)
binfiles="sh bash cat cp dd killall ls mkdir mknod mount mountpoint"
binfiles="$binfiles umount ln rm uname readlink basename"
binfiles="$binfiles chmod chown find sleep echo printf"

# udevadm - cari di semua lokasi
if [ -x /usr/bin/udevadm ]; then
  binfiles="$binfiles udevadm"
elif [ -x /sbin/udevadm ]; then
  binfiles="$binfiles udevadm"
elif [ -x /bin/udevadm ]; then
  binfiles="$binfiles udevadm"
fi

sbinfiles="modprobe blkid switch_root"

# udevd - cari di semua lokasi
for f in udevd systemd-udevd; do
  if   [ -x /usr/sbin/$f ]; then
    sbinfiles="$sbinfiles $f"
  elif [ -x /sbin/$f ]; then
    sbinfiles="$sbinfiles $f"
  elif [ -x /usr/lib/udev/$f ]; then
    sbinfiles="$sbinfiles $f"
  elif [ -x /lib/udev/$f ]; then
    sbinfiles="$sbinfiles $f"
  fi
done

# ===================== SETUP WORKDIR =====================

unsorted=$(mktemp /tmp/unsorted.XXXXXXXXXX)

DATADIR=/usr/share/mkinitramfs
INITIN=init.in

# Check if init script exists
if [ ! -f "$DATADIR/$INITIN" ]; then
  echo "ERROR: Init script not found at $DATADIR/$INITIN"
  echo "Please create $DATADIR/$INITIN first"
  exit 1
fi

WDIR=$(mktemp -d /tmp/initrd-work.XXXXXXXXXX)

# Buat struktur direktori lengkap
mkdir -p $WDIR/{dev,run,sys,proc,tmp,tmpmnt,usr/{bin,lib/{firmware,modules},sbin}}
mkdir -p $WDIR/{mnt,squash,cow/{upper,work},.root}
mkdir -p $WDIR/etc/{modprobe.d,udev/rules.d}

touch $WDIR/etc/modprobe.d/modprobe.conf

# Symlinks standar
ln -s usr/bin  $WDIR/bin
ln -s usr/lib  $WDIR/lib
ln -s usr/sbin $WDIR/sbin
ln -s lib      $WDIR/lib64

# ===================== DEVICE NODES =====================

# Device nodes minimal
mknod -m 640 $WDIR/dev/console c 5 1 2>/dev/null
mknod -m 664 $WDIR/dev/null    c 1 3 2>/dev/null
mknod -m 640 $WDIR/dev/kmsg    c 1 11 2>/dev/null

# Loop devices (dibutuhkan untuk mount squashfs)
for i in 0 1 2 3 4 5 6 7; do
  mknod -m 660 $WDIR/dev/loop$i b 7 $i 2>/dev/null
done

# ===================== UDEV CONFIG =====================

# udev config
if [ -f /etc/udev/udev.conf ]; then
  cp /etc/udev/udev.conf $WDIR/etc/udev/udev.conf
fi

# udev rules
if [ -d /etc/udev/rules.d ]; then
  for file in /etc/udev/rules.d/*.rules; do
    [ -f "$file" ] && cp "$file" "$WDIR/etc/udev/rules.d/"
  done
fi

# Firmware (optional)
if [ -d /lib/firmware ]; then
  cp -a /lib/firmware $WDIR/usr/lib/ 2>/dev/null || true
fi

# ===================== INSTALL INIT SCRIPT =====================

install -m0755 $DATADIR/$INITIN $WDIR/init
echo "Installed init script"

# ===================== INSTALL BINARIES =====================

# Install binaries dari /usr/bin atau /bin
echo "Installing binaries..."
for f in $binfiles ; do
  found=0
  for dir in /usr/bin /bin; do
    if [ -x "$dir/$f" ]; then
      ldd "$dir/$f" 2>/dev/null | sed "s/\t//" | cut -d " " -f1 >> $unsorted 2>/dev/null
      copy "$f" bin
      found=1
      break
    fi
  done
  if [ $found -eq 0 ]; then
    echo "Warning: $f not found"
  fi
done

# Install sbinaries dari /usr/sbin atau /sbin
echo "Installing sbinaries..."
for f in $sbinfiles ; do
  found=0
  for dir in /usr/sbin /sbin; do
    if [ -x "$dir/$f" ]; then
      ldd "$dir/$f" 2>/dev/null | sed "s/\t//" | cut -d " " -f1 >> $unsorted 2>/dev/null
      copy "$f" sbin
      found=1
      break
    fi
  done
  if [ $found -eq 0 ]; then
    echo "Warning: $f not found in sbin"
  fi
done

# ===================== INSTALL UDEV =====================

echo "Installing udev..."
UDEVD_FOUND=0

# Copy udevd dari semua kemungkinan lokasi
for udevd_path in \
  /usr/lib/udev/udevd \
  /lib/udev/udevd \
  /usr/lib/systemd/systemd-udevd \
  /lib/systemd/systemd-udevd \
  /usr/sbin/udevd \
  /sbin/udevd \
  /usr/bin/udevd
do
  if [ -x "$udevd_path" ]; then
    # Tentukan target path
    case "$udevd_path" in
      */udev/udevd)
        mkdir -p "$WDIR/usr/lib/udev"
        cp "$udevd_path" "$WDIR/usr/lib/udev/udevd"
        echo "  Copied udevd from $udevd_path to /usr/lib/udev/"
        # Copy dependencies
        ldd "$udevd_path" 2>/dev/null | while read line; do
          case "$line" in
            *"=>"*)
              lib=$(echo "$line" | sed 's/.*=> //' | sed 's/ (0x.*//')
              [ -f "$lib" ] && cp "$lib" "$WDIR/usr/lib/" 2>/dev/null
              ;;
          esac
        done
        UDEVD_FOUND=1
        break
        ;;
      */systemd/*)
        mkdir -p "$WDIR/usr/lib/systemd"
        cp "$udevd_path" "$WDIR/usr/lib/systemd/systemd-udevd"
        echo "  Copied systemd-udevd from $udevd_path"
        UDEVD_FOUND=1
        break
        ;;
      *)
        mkdir -p "$WDIR/usr/sbin"
        cp "$udevd_path" "$WDIR/usr/sbin/udevd"
        echo "  Copied udevd from $udevd_path to /usr/sbin/"
        UDEVD_FOUND=1
        break
        ;;
    esac
  fi
done

if [ $UDEVD_FOUND -eq 0 ]; then
  echo "WARNING: udevd not found anywhere! udev will not work."
fi

# Copy udevadm if found separately
for udevadm_path in /usr/bin/udevadm /sbin/udevadm /bin/udevadm; do
  if [ -x "$udevadm_path" ] && [ ! -f "$WDIR/usr/bin/udevadm" ]; then
    cp "$udevadm_path" "$WDIR/usr/bin/udevadm"
    echo "  Copied udevadm from $udevadm_path"
    # Copy dependencies
    ldd "$udevadm_path" 2>/dev/null | while read line; do
      case "$line" in
        *"=>"*)
          lib=$(echo "$line" | sed 's/.*=> //' | sed 's/ (0x.*//')
          [ -f "$lib" ] && cp "$lib" "$WDIR/usr/lib/" 2>/dev/null
          ;;
      esac
    done
    break
  fi
done

# Copy direktori udev helpers
for udev_dir in /usr/lib/udev /lib/udev; do
  if [ -d "$udev_dir" ]; then
    cp -a "$udev_dir" "$WDIR/usr/lib/" 2>/dev/null
    echo "  Copied udev helpers from $udev_dir"
    break
  fi
done

# ===================== INSTALL LIBRARIES =====================

echo "Installing libraries..."
if [ -s "$unsorted" ]; then
  sort "$unsorted" | uniq | while read library ; do
    case "$library" in
      linux-vdso.so*|linux-gate.so*|libsystemd-shared*|ld-*)
        continue ;;
    esac

    # Cari library di berbagai lokasi
    lib_file=""
    for libdir in /usr/lib /lib /usr/lib64 /lib64 /usr/lib/x86_64-linux-gnu /lib/x86_64-linux-gnu; do
      if [ -f "$libdir/$library" ]; then
        lib_file="$libdir/$library"
        break
      fi
    done

    if [ -n "$lib_file" ]; then
      cp "$lib_file" "$WDIR/usr/lib/" 2>/dev/null
      echo "  Copied lib: $library"
    else
      echo "  Warning: Library not found: $library"
    fi
  done
fi

# Copy ld-linux if needed
for ld in /lib64/ld-linux-x86-64.so.2 /lib/ld-linux.so.2 /usr/lib/ld-linux.so; do
  if [ -f "$ld" ] && [ ! -f "$WDIR/usr/lib/$(basename $ld)" ]; then
    cp "$ld" "$WDIR/usr/lib/"
    echo "  Copied ld-linux: $ld"
  fi
done

# ===================== INSTALL KERNEL MODULES =====================

if [ -n "$KERNEL_VERSION" ]; then
  echo "Installing kernel modules for $KERNEL_VERSION..."

  # Daftar modul yang diperlukan
  modules_needed="squashfs overlay loop vfat iso9660 usb-storage sr_mod"
  modules_needed="$modules_needed xhci-hcd ehci-hcd uhci-hcd"
  modules_needed="$modules_needed virtio-gpu virtio-net virtio_blk"
  
  for mod in $modules_needed; do
    mod_path=$(find /lib/modules/$KERNEL_VERSION -name "${mod}.ko*" 2>/dev/null | head -1)
    if [ -n "$mod_path" ]; then
      # Copy module file
      mkdir -p "$WDIR/usr/lib/modules/$KERNEL_VERSION/$(dirname ${mod_path#/lib/modules/$KERNEL_VERSION/})"
      cp "$mod_path" "$WDIR/usr/lib/modules/$KERNEL_VERSION/${mod_path#/lib/modules/$KERNEL_VERSION/}"
      echo "  Added module: $mod"
    fi
  done

  # Copy modules.dep dan related files
  mkdir -p $WDIR/usr/lib/modules/$KERNEL_VERSION
  for f in modules.dep modules.dep.bin modules.alias modules.alias.bin \
           modules.symbols modules.symbols.bin modules.builtin modules.builtin.bin \
           modules.builtin.modinfo modules.order; do
    if [ -f "/lib/modules/$KERNEL_VERSION/$f" ]; then
      cp "/lib/modules/$KERNEL_VERSION/$f" "$WDIR/usr/lib/modules/$KERNEL_VERSION/" 2>/dev/null
    fi
  done

  # Also copy to /lib/modules for compatibility
  mkdir -p $WDIR/lib/modules/$KERNEL_VERSION
  cp -a $WDIR/usr/lib/modules/$KERNEL_VERSION/* $WDIR/lib/modules/$KERNEL_VERSION/ 2>/dev/null

  # Run depmod
  depmod -b $WDIR $KERNEL_VERSION 2>/dev/null
  echo "Kernel modules installed"
fi

# ===================== CREATE INITRAMFS =====================

( cd $WDIR ; find . -print | cpio -o -H newc --quiet | gzip -9 ) > $INITRAMFS_FILE

# Tampilkan ukuran
SIZE=$(du -sh $INITRAMFS_FILE | cut -f1)
echo "done. (size: $SIZE)"

# ===================== VERIFICATION =====================

echo ""
echo "=== Verifying critical binaries ==="
critical_files="init usr/bin/sh usr/sbin/switch_root usr/bin/mount"
critical_files="$critical_files usr/sbin/modprobe usr/bin/ls usr/bin/cat"

for f in $critical_files; do
  if [ -f "$WDIR/$f" ] || [ -L "$WDIR/$f" ]; then
    echo "  OK: /$f"
  else
    echo "  MISSING: /$f  <-- WARNING!"
  fi
done

# Verify udev
echo ""
echo "=== udev verification ==="
if [ -f "$WDIR/usr/lib/udev/udevd" ] || [ -f "$WDIR/usr/sbin/udevd" ] || [ -f "$WDIR/usr/lib/systemd/systemd-udevd" ]; then
  echo "  OK: udevd found"
else
  echo "  WARNING: udevd not found!"
fi

if [ -f "$WDIR/usr/bin/udevadm" ]; then
  echo "  OK: udevadm found"
else
  echo "  WARNING: udevadm not found!"
fi

# ===================== CLEANUP =====================

rm -rf $WDIR $unsorted 2>/dev/null

echo ""
echo "Done! Initramfs created: $INITRAMFS_FILE"
