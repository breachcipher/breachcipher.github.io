#!/bin/sh
# Init script for LeakOS Live ISO - Fixed overlay writable issue

PATH=/usr/bin:/usr/sbin:/bin:/sbin
export PATH

# Global variables
DEBUG=false
rootdelay=
device=
mnt_tmp="/tmpmnt"

# ===================== LOGGING FUNCTIONS =====================

log_msg() {
    local msg="[INIT] $*"
    echo "$msg" > /dev/kmsg 2>/dev/null || true
    echo "$msg"
}

problem() {
    log_msg "ERROR: Problem detected!"
    printf "\nEncountered a problem!\nDropping to shell...\n\n"
    exec /bin/sh
}

# ===================== BOOT MEDIA DETECTION =====================

find_boot_device() {
    local timeout=30
    local count=0
    local mnt_tmp_local="/tmpmnt_detect"

    log_msg "Auto-detecting boot media (timeout: ${timeout}s)..."
    log_msg "Looking for lfs.squashfs on available devices..."

    mkdir -p "$mnt_tmp_local" 2>/dev/null

    while [ $count -lt $timeout ]; do
        for dev in $(lsblk -pnlo NAME 2>/dev/null | grep -E '^(/dev/sd|/dev/hd|/dev/nvme|/dev/vd|/dev/mmc)' | head -10); do
            if [ -n "$dev" ] && [ -b "$dev" ]; then
                log_msg "Probing device $dev..."

                if mount -t auto -o ro "$dev" "$mnt_tmp_local" 2>/dev/null; then
                    # Check multiple possible paths
                    if [ -f "$mnt_tmp_local/boot/lfs.squashfs" ]; then
                        device="$dev"
                        log_msg "Boot media DETECTED on $dev (found /boot/lfs.squashfs)"
                        echo "$mnt_tmp_local" > /tmp/boot_mount_point
                        return 0
                    elif [ -f "$mnt_tmp_local/lfs.squashfs" ]; then
                        device="$dev"
                        log_msg "Boot media DETECTED on $dev (found /lfs.squashfs)"
                        echo "$mnt_tmp_local" > /tmp/boot_mount_point
                        return 0
                    elif [ -f "$mnt_tmp_local/root.squashfs" ]; then
                        device="$dev"
                        log_msg "Boot media DETECTED on $dev (found /root.squashfs)"
                        echo "$mnt_tmp_local" > /tmp/boot_mount_point
                        return 0
                    else
                        umount "$mnt_tmp_local" 2>/dev/null
                    fi
                fi
            fi
        done

        # Also check CDROM devices
        for dev in /dev/sr0 /dev/cdrom; do
            if [ -b "$dev" ]; then
                log_msg "Probing CDROM $dev..."
                if mount -t iso9660 -o ro "$dev" "$mnt_tmp_local" 2>/dev/null; then
                    if [ -f "$mnt_tmp_local/boot/lfs.squashfs" ]; then
                        device="$dev"
                        log_msg "Boot media DETECTED on $dev"
                        echo "$mnt_tmp_local" > /tmp/boot_mount_point
                        return 0
                    else
                        umount "$mnt_tmp_local" 2>/dev/null
                    fi
                fi
            fi
        done

        sleep 2
        count=$((count + 2))
        [ $((count % 10)) -eq 0 ] && log_msg "Still scanning... (${count}s)"
    done

    log_msg "ERROR: No valid boot media found after ${timeout}s"
    
    log_msg "Available block devices:"
    lsblk 2>/dev/null || true
    
    problem
    return 1
}

# ===================== USER MANAGEMENT =====================

ensure_users() {
    log_msg "Ensuring user database exists in overlay..."
    
    mkdir -p /.root/etc /.root/home /.root/root /.root/var /tmp/overlay-work
    
    # Create /etc/passwd
    if [ ! -f /.root/etc/passwd ]; then
        cat > /.root/etc/passwd << 'EOF'
root:x:0:0:root:/root:/bin/bash
leakos:x:1000:1000:Live User:/home/leakos:/bin/bash
nobody:x:65534:65534:nobody:/nonexistent:/usr/sbin/nologin
EOF
    fi
    
    # Create /etc/group
    if [ ! -f /.root/etc/group ]; then
        cat > /.root/etc/group << 'EOF'
root:x:0:
leakos:x:1000:
nogroup:x:65534:
users:x:100:
EOF
    fi
    
    # Create /etc/shadow
    if [ ! -f /.root/etc/shadow ]; then
        cat > /.root/etc/shadow << 'EOF'
root::19490:0:99999:7:::
leakos::19490:0:99999:7:::
nobody:*:19490:0:99999:7:::
EOF
        chmod 600 /.root/etc/shadow 2>/dev/null
    fi
    
    # Create home directory
    if [ ! -d /.root/home/leakos ]; then
        mkdir -p /.root/home/leakos/{Desktop,Documents,Downloads,Music,Pictures,Videos,Public,Templates}
        mkdir -p /.root/home/leakos/.config /.root/home/leakos/.cache
        chown -R 1000:1000 /.root/home/leakos 2>/dev/null
    fi
    
    log_msg "User setup complete"
}

# ===================== ROOT FILESYSTEM SETUP =====================

do_mount_root() {
    local boot_mount_point
    
    log_msg "Mounting root filesystem (squashfs + overlay)"
    
    # Load kernel modules
    log_msg "Loading kernel modules..."
    modprobe -q squashfs 2>/dev/null && log_msg "  Loaded squashfs" || log_msg "  squashfs module missing"
    modprobe -q overlay 2>/dev/null && log_msg "  Loaded overlay" || log_msg "  overlay module missing"
    modprobe -q loop 2>/dev/null && log_msg "  Loaded loop" || log_msg "  loop module missing"
    
    # Create mount points
    mkdir -p /.root /mnt /squash /cow /cow/upper /cow/work 2>/dev/null
    
    # Auto-detect boot device
    if ! find_boot_device; then
        log_msg "Failed to find boot device"
        return 1
    fi
    
    # Get the mount point from detection
    if [ -f /tmp/boot_mount_point ]; then
        boot_mount_point=$(cat /tmp/boot_mount_point)
        rm -f /tmp/boot_mount_point
    else
        boot_mount_point="/tmpmnt_detect"
    fi
    
    # Move or mount to /mnt
    if mountpoint -q "$boot_mount_point" 2>/dev/null; then
        log_msg "Moving boot media from $boot_mount_point to /mnt"
        mount --move "$boot_mount_point" /mnt || {
            log_msg "Failed to move mount point"
            problem
            return 1
        }
    else
        log_msg "Mounting $device directly to /mnt"
        mount -t auto "$device" /mnt || {
            log_msg "Mount $device failed"
            problem
            return 1
        }
    fi
    
    log_msg "Boot media mounted at /mnt"
    
    # Find squashfs file
    SQUASHFS_PATH=""
    for path in /mnt/boot/lfs.squashfs /mnt/lfs.squashfs /mnt/root.squashfs; do
        if [ -f "$path" ]; then
            SQUASHFS_PATH="$path"
            log_msg "Found squashfs at $SQUASHFS_PATH"
            break
        fi
    done
    
    if [ -z "$SQUASHFS_PATH" ]; then
        log_msg "ERROR: No squashfs file found!"
        log_msg "Contents of /mnt:"
        ls -la /mnt/ 2>/dev/null || true
        problem
        return 1
    fi
    
    # Mount squashfs
    log_msg "Mounting squashfs from $SQUASHFS_PATH"
    mount -t squashfs -o loop,ro "$SQUASHFS_PATH" /squash || {
        log_msg "ERROR: Failed to mount squashfs!"
        problem
        return 1
    }
    log_msg "Squashfs mounted at /squash"
    
    # Verify squashfs content
    if [ -z "$(ls -A /squash 2>/dev/null)" ]; then
        log_msg "ERROR: Squashfs mounted but appears empty!"
        problem
        return 1
    fi
    
    # FIX: Mount tmpfs for overlay dengan ukuran yang cukup
    log_msg "Mounting tmpfs for overlay (512MB)..."
    mount -t tmpfs -o size=512M,mode=755 tmpfs /cow || {
        log_msg "ERROR: Failed to mount tmpfs on /cow"
        problem
        return 1
    }
    
    # Create working directories with proper structure
    mkdir -p /cow/upper /cow/work
    
    # FIX: Check if filesystem supports xattr (required for overlay)
    log_msg "Testing tmpfs for xattr support..."
    if ! attr -l /cow 2>/dev/null && ! getfattr -d /cow 2>/dev/null; then
        log_msg "Warning: tmpfs may not support xattr, but continuing..."
    fi
    
    # FIX: Mount overlay dengan options yang benar
    log_msg "Mounting overlay filesystem..."
    mount -t overlay overlay \
        -o lowerdir=/squash,upperdir=/cow/upper,workdir=/cow/work \
        /.root 2>&1 | while read line; do log_msg "  overlay: $line"; done
    
    if ! mountpoint -q /.root; then
        log_msg "ERROR: Failed to mount overlay!"
        
        # Try alternative: use ramfs instead of tmpfs
        log_msg "Retrying with ramfs instead of tmpfs..."
        umount /cow 2>/dev/null
        mount -t ramfs -o size=512M ramfs /cow
        mkdir -p /cow/upper /cow/work
        
        mount -t overlay overlay \
            -o lowerdir=/squash,upperdir=/cow/upper,workdir=/cow/work \
            /.root || {
            log_msg "ERROR: Overlay still failing!"
            problem
            return 1
        }
    fi
    
    log_msg "Overlay mounted at /.root"
    
    # Verify overlay is writable
    log_msg "Testing overlay writability..."
    if touch /.root/test_write 2>/dev/null; then
        rm -f /.root/test_write
        log_msg "Overlay is writable OK"
    else
        log_msg "ERROR: Overlay is not writable!"
        log_msg "Check overlay mount options:"
        mount | grep overlay | while read line; do log_msg "  $line"; done
        problem
        return 1
    fi
    
    # Setup user files
    ensure_users
    
    # Verify init exists
    if [ ! -x "/.root/sbin/init" ] && [ ! -x "/.root/bin/init" ]; then
        log_msg "WARNING: No init found, creating fallback..."
        # Create minimal init if needed (for testing)
        if [ -f "/.root/bin/bash" ]; then
            cat > /.root/sbin/init << 'EOF'
#!/bin/bash
echo "=== Minimal init ==="
mount -t proc proc /proc
mount -t sysfs sysfs /sys
mount -t devtmpfs devtmpfs /dev
exec /bin/bash
EOF
            chmod 755 /.root/sbin/init
        fi
    fi
    
    log_msg "Root filesystem prepared successfully!"
    return 0
}

# ===================== MAIN =====================

# Parse cmdline
for param in $(cat /proc/cmdline 2>/dev/null || echo ""); do
    case $param in
        debug) DEBUG=true; set -x ;;
        rootdelay=*) rootdelay=${param#rootdelay=} ;;
    esac
done

log_msg "=== LeakOS Live ISO Init Starting ==="

# Create essential directories
mkdir -p /proc /sys /dev /run /tmp /dev/pts 2>/dev/null

# Mount pseudo-filesystems
log_msg "Mounting pseudo-filesystems..."

mount -t devtmpfs devtmpfs /dev 2>/dev/null || {
    log_msg "devtmpfs failed"
    mount -t tmpfs tmpfs /dev
    mknod -m 622 /dev/console c 5 1 2>/dev/null
    mknod -m 666 /dev/null c 1 3 2>/dev/null
    mknod -m 666 /dev/zero c 1 5 2>/dev/null
}

mount -t proc proc /proc || {
    log_msg "CRITICAL: proc mount failed!"
    problem
}

mount -t sysfs sysfs /sys 2>/dev/null || log_msg "sysfs mount failed"
mount -t tmpfs tmpfs /run -o mode=755 2>/dev/null || true
mount -t devpts devpts /dev/pts -o gid=5,mode=620 2>/dev/null || true

# Start udev if available
log_msg "Starting udev..."
if [ -x /sbin/udevd ]; then
    /sbin/udevd --daemon 2>/dev/null
    udevadm trigger 2>/dev/null
    udevadm settle --timeout=10 2>/dev/null
    log_msg "udev started"
fi

# Apply rootdelay
[ -n "$rootdelay" ] && sleep "$rootdelay"

# Mount root filesystem
log_msg "Setting up root filesystem..."
if ! do_mount_root; then
    log_msg "Failed to setup root filesystem!"
    problem
fi

# Cleanup udev
killall udevd 2>/dev/null || true

# Create device nodes in new root
[ ! -c "/.root/dev/console" ] && mknod -m 622 /.root/dev/console c 5 1 2>/dev/null
[ ! -c "/.root/dev/null" ] && mknod -m 666 /.root/dev/null c 1 3 2>/dev/null
[ ! -c "/.root/dev/zero" ] && mknod -m 666 /.root/dev/zero c 1 5 2>/dev/null

# Final check
if [ ! -x "/.root/sbin/init" ] && [ ! -x "/.root/bin/init" ]; then
    log_msg "FATAL: No init found!"
    log_msg "Contents of /.root:"
    ls -la /.root/ 2>/dev/null | head -20
    problem
fi

# Switch to new root
log_msg "Switching to new root..."

if [ -x "/.root/sbin/init" ]; then
    exec switch_root /.root /sbin/init
elif [ -x "/.root/bin/init" ]; then
    exec switch_root /.root /bin/init
else
    exec switch_root /.root /bin/sh
fi

# Fallback
problem
