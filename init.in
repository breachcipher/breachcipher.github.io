#!/bin/sh
# Init script for custom LFS Live ISO - Coreutils version (no BusyBox)
# Auto-detect boot media, robust /proc mount handling

PATH=/usr/bin:/usr/sbin:/bin:/sbin
export PATH

# Global variables
DEBUG=false
rootdelay=
device=
mnt_tmp="/tmpmnt"

# ===================== LOGGING FUNCTIONS =====================

log_msg() {
    local msg="[INIT] $*"
    echo "$msg" > /dev/kmsg 2>/dev/null || true
    echo "$msg"
}

problem() {
    log_msg "ERROR: Problem detected!"
    printf "\nEncountered a problem!\nDropping to shell...\n\n"
    exec /bin/sh
}

# ===================== BOOT MEDIA DETECTION =====================

find_boot_device() {
    local timeout=30
    local count=0
    local mnt_tmp_local="/tmpmnt_detect"

    log_msg "Auto-detecting boot media (timeout: ${timeout}s)..."
    log_msg "Looking for /boot/lfs.squashfs on available devices..."

    mkdir -p "$mnt_tmp_local" 2>/dev/null

    while [ $count -lt $timeout ]; do
        for dev in $(lsblk -pnlo NAME 2>/dev/null || echo ""); do
            if [ -n "$dev" ] && [ -b "$dev" ]; then
                log_msg "Probing device $dev..."

                if mount -t auto -o ro "$dev" "$mnt_tmp_local" 2>/dev/null; then
                    # Check multiple possible paths
                    if [ -f "$mnt_tmp_local/boot/lfs.squashfs" ]; then
                        device="$dev"
                        log_msg "Boot media DETECTED on $dev (found /boot/lfs.squashfs)"
                        # Keep mounted for caller
                        echo "$mnt_tmp_local" > /tmp/boot_mount_point
                        return 0
                    elif [ -f "$mnt_tmp_local/lfs.squashfs" ]; then
                        device="$dev"
                        log_msg "Boot media DETECTED on $dev (found /lfs.squashfs)"
                        echo "$mnt_tmp_local" > /tmp/boot_mount_point
                        return 0
                    else
                        umount "$mnt_tmp_local" 2>/dev/null
                    fi
                fi
            fi
        done

        sleep 2
        count=$((count + 2))
        [ $((count % 10)) -eq 0 ] && log_msg "Still scanning... (${count}s)"
    done

    log_msg "ERROR: No valid boot media found after ${timeout}s"
    
    # Debug: list all block devices
    log_msg "Available block devices:"
    lsblk -pnlo NAME,SIZE,FSTYPE 2>/dev/null | while read line; do log_msg "  $line"; done
    
    problem
    return 1
}

# ===================== USER MANAGEMENT =====================

ensure_users() {
    log_msg "Ensuring user database exists in overlay..."
    
    # Create essential directories
    mkdir -p /.root/etc /.root/home /.root/root
    
    # Create /etc/passwd if missing
    if [ ! -f /.root/etc/passwd ] || [ ! -s /.root/etc/passwd ]; then
        log_msg "Creating minimal /etc/passwd in overlay..."
        cat > /.root/etc/passwd << 'EOF'
root:x:0:0:root:/root:/bin/bash
leakos:x:1000:1000:Live User:/home/leakos:/bin/bash
nobody:x:65534:65534:nobody:/nonexistent:/usr/sbin/nologin
EOF
    fi
    
    # Create /etc/group if missing
    if [ ! -f /.root/etc/group ] || [ ! -s /.root/etc/group ]; then
        log_msg "Creating minimal /etc/group in overlay..."
        cat > /.root/etc/group << 'EOF'
root:x:0:
leakos:x:1000:
nogroup:x:65534:
users:x:100:
EOF
    fi
    
    # Create /etc/shadow if missing
    if [ ! -f /.root/etc/shadow ] || [ ! -s /.root/etc/shadow ]; then
        log_msg "Creating minimal /etc/shadow in overlay..."
        cat > /.root/etc/shadow << 'EOF'
root::19490:0:99999:7:::
leakos::19490:0:99999:7:::
nobody:*:19490:0:99999:7:::
EOF
        chmod 600 /.root/etc/shadow 2>/dev/null
    fi
    
    # Create /etc/pam.d directory and basic config
    mkdir -p /.root/etc/pam.d
    
    if [ ! -f /.root/etc/pam.d/common-auth ]; then
        cat > /.root/etc/pam.d/common-auth << 'EOF'
auth    sufficient      pam_unix.so nullok
auth    required        pam_deny.so
EOF
    fi
    
    # Create home directory for live user
    if [ ! -d /.root/home/leakos ]; then
        log_msg "Creating home directory for live user with standard folders..."
        mkdir -p /.root/home/leakos
        
        # Standard XDG user directories
        for folder in Desktop Documents Downloads Music Pictures Videos Public Templates; do
            mkdir -p "/.root/home/leakos/$folder"
        done
        
        # Hidden directories
        for folder in .local/share .config .cache .ssh .gnupg; do
            mkdir -p "/.root/home/leakos/$folder"
        done
        
        # Application directories
        mkdir -p /.root/home/leakos/{temp,bin,.local/bin}
        
        # Set permissions
        chown -R 1000:1000 /.root/home/leakos 2>/dev/null
        chmod 700 /.root/home/leakos 2>/dev/null
        chmod 755 /.root/home/leakos/* 2>/dev/null
        chmod 700 /.root/home/leakos/.ssh /.root/home/leakos/.gnupg 2>/dev/null
        
        log_msg "Created standard folders for live user"
    fi
    
    # Create /etc/skel template
    if [ ! -d /.root/etc/skel ]; then
        log_msg "Creating /etc/skel with standard configuration..."
        mkdir -p /.root/etc/skel
        
        # Standard folders in skel
        for folder in Desktop Documents Downloads Music Pictures Videos Public Templates; do
            mkdir -p "/.root/etc/skel/$folder"
        done
        
        for folder in .local/share .config .cache; do
            mkdir -p "/.root/etc/skel/$folder"
        done
        
        # Create .bashrc
        cat > /.root/etc/skel/.bashrc << 'EOF'
# ~/.bashrc

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# History settings
HISTCONTROL=ignoreboth
HISTSIZE=1000
HISTFILESIZE=2000

# Check window size
shopt -s checkwinsize

# Color prompt
if [ -x /usr/bin/tput ] && tput setaf 1 >&/dev/null; then
    PS1='\[\033[01;32m\]\u@\h\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '
else
    PS1='\u@\h:\w\$ '
fi

# Color support for ls
if [ -x /usr/bin/dircolors ]; then
    alias ls='ls --color=auto'
    alias grep='grep --color=auto'
fi

# Aliases
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
EOF
        
        # Create .profile
        cat > /.root/etc/skel/.profile << 'EOF'
# ~/.profile

if [ -n "$BASH_VERSION" ]; then
    if [ -f "$HOME/.bashrc" ]; then
        . "$HOME/.bashrc"
    fi
fi

# User bin directories
if [ -d "$HOME/bin" ]; then
    PATH="$HOME/bin:$PATH"
fi
if [ -d "$HOME/.local/bin" ]; then
    PATH="$HOME/.local/bin:$PATH"
fi
export PATH
EOF
        
        chmod 644 /.root/etc/skel/.bashrc /.root/etc/skel/.profile 2>/dev/null
        log_msg "/etc/skel created"
    fi
    
    # Copy skel files to home if needed
    if [ ! -f /.root/home/leakos/.bashrc ]; then
        log_msg "Copying skel files to live user home..."
        cp -r /.root/etc/skel/. /.root/home/leakos/ 2>/dev/null || true
        chown -R 1000:1000 /.root/home/leakos/ 2>/dev/null
    fi
    
    # Create .Xresources
    if [ ! -f /.root/home/leakos/.Xresources ]; then
        cat > /.root/home/leakos/.Xresources << 'EOF'
! X resources
Xft.dpi: 96
Xft.antialias: true
Xft.hinting: true
Xft.rgba: rgb

! URxvt settings
URxvt.font: xft:Monospace:size=10
URxvt.background: #000000
URxvt.foreground: #00FF00
URxvt.cursorColor: #00FF00
URxvt.scrollBar: false
URxvt.saveLines: 10000
EOF
        chown 1000:1000 /.root/home/leakos/.Xresources 2>/dev/null
    fi
    
    # Create XDG user dirs config
    if [ ! -f /.root/home/leakos/.config/user-dirs.dirs ]; then
        mkdir -p /.root/home/leakos/.config
        cat > /.root/home/leakos/.config/user-dirs.dirs << 'EOF'
XDG_DESKTOP_DIR="$HOME/Desktop"
XDG_DOCUMENTS_DIR="$HOME/Documents"
XDG_DOWNLOAD_DIR="$HOME/Downloads"
XDG_MUSIC_DIR="$HOME/Music"
XDG_PICTURES_DIR="$HOME/Pictures"
XDG_VIDEOS_DIR="$HOME/Videos"
XDG_PUBLICSHARE_DIR="$HOME/Public"
XDG_TEMPLATES_DIR="$HOME/Templates"
EOF
        chown -R 1000:1000 /.root/home/leakos/.config 2>/dev/null
    fi
    
    log_msg "User setup complete"
}

# ===================== ROOT FILESYSTEM SETUP =====================

verify_root_filesystem() {
    log_msg "Verifying root filesystem integrity..."
    
    # Check for init
    if [ ! -x "/.root/sbin/init" ] && [ ! -x "/.root/bin/init" ] && [ ! -x "/.root/init" ]; then
        log_msg "ERROR: No init found in /.root!"
        log_msg "Contents of /.root:"
        ls -la /.root/ 2>/dev/null | while read line; do log_msg "  $line"; done
        
        # Check if squashfs was empty
        if [ -d /squash ]; then
            log_msg "Contents of squashfs:"
            ls -la /squash/ 2>/dev/null | while read line; do log_msg "  $line"; done
        fi
        
        # Try to find init anywhere
        init_path=$(find /.root -name "init" -type f -executable 2>/dev/null | head -1)
        if [ -n "$init_path" ]; then
            log_msg "Found init at $init_path, creating symlink..."
            ln -sf "$init_path" /.root/sbin/init 2>/dev/null || true
            ln -sf "$init_path" /.root/init 2>/dev/null || true
        else
            log_msg "CRITICAL: No init system found in root filesystem!"
            return 1
        fi
    fi
    
    # Verify essential directories
    for dir in proc sys dev run tmp var; do
        if [ ! -d "/.root/$dir" ]; then
            log_msg "Creating essential directory: /.root/$dir"
            mkdir -p "/.root/$dir"
        fi
    done
    
    # Verify essential files
    if [ ! -f "/.root/etc/fstab" ]; then
        log_msg "Creating minimal /etc/fstab..."
        cat > /.root/etc/fstab << 'EOF'
proc            /proc           proc    defaults        0       0
sysfs           /sys            sysfs   defaults        0       0
devtmpfs        /dev            devtmpfs defaults      0       0
tmpfs           /tmp            tmpfs   defaults        0       0
EOF
    fi
    
    log_msg "Root filesystem verification complete"
    return 0
}

do_mount_root() {
    local boot_mount_point
    
    log_msg "Mounting root filesystem (squashfs + overlay)"
    
    # Load kernel modules
    log_msg "Loading kernel modules..."
    for mod in squashfs overlay loop vfat iso9660 usb-storage sr_mod; do
        modprobe -q "$mod" 2>/dev/null && log_msg "  Loaded $mod" || log_msg "  Failed to load $mod (non-fatal)"
    done
    
    # Create mount points
    mkdir -p /.root /mnt /squash /cow /cow/mod /cow/buffer 2>/dev/null
    
    # Auto-detect boot device
    if ! find_boot_device; then
        log_msg "Failed to find boot device"
        return 1
    fi
    
    # Get the mount point from detection
    if [ -f /tmp/boot_mount_point ]; then
        boot_mount_point=$(cat /tmp/boot_mount_point)
        rm -f /tmp/boot_mount_point
    else
        boot_mount_point="/tmpmnt_detect"
    fi
    
    # Move or mount to /mnt
    if mountpoint -q "$boot_mount_point"; then
        log_msg "Moving boot media from $boot_mount_point to /mnt"
        mount --move "$boot_mount_point" /mnt || {
            log_msg "Failed to move mount point"
            problem
            return 1
        }
    else
        log_msg "Mounting $device directly to /mnt"
        mount -t auto "$device" /mnt || {
            log_msg "Mount $device failed"
            problem
            return 1
        }
    fi
    
    log_msg "Boot media mounted at /mnt"
    
    # Find squashfs file (check multiple locations)
    SQUASHFS_PATH=""
    for path in /mnt/boot/lfs.squashfs /mnt/lfs.squashfs /mnt/root.squashfs /mnt/filesystem.squashfs; do
        if [ -f "$path" ]; then
            SQUASHFS_PATH="$path"
            log_msg "Found squashfs at $SQUASHFS_PATH"
            break
        fi
    done
    
    if [ -z "$SQUASHFS_PATH" ]; then
        log_msg "ERROR: No squashfs file found!"
        log_msg "Contents of /mnt:"
        ls -la /mnt/ 2>/dev/null | while read line; do log_msg "  $line"; done
        log_msg "Contents of /mnt/boot:"
        ls -la /mnt/boot/ 2>/dev/null | while read line; do log_msg "  $line"; done
        problem
        return 1
    fi
    
    # Mount squashfs
    log_msg "Mounting squashfs from $SQUASHFS_PATH"
    mount -t squashfs -o loop "$SQUASHFS_PATH" /squash || {
        log_msg "ERROR: Failed to mount squashfs!"
        problem
        return 1
    }
    log_msg "Squashfs mounted at /squash"
    
    # Verify squashfs content
    if [ -z "$(ls -A /squash 2>/dev/null)" ]; then
        log_msg "ERROR: Squashfs mounted but appears empty!"
        problem
        return 1
    fi
    
    log_msg "Squashfs contains: $(ls /squash 2>/dev/null | head -5 | tr '\n' ' ')"
    
    # Mount tmpfs for overlay
    log_msg "Mounting tmpfs for overlay"
    mount -t tmpfs tmpfs /cow || {
        log_msg "ERROR: Failed to mount tmpfs on /cow"
        problem
        return 1
    }
    
    # Create working directories
    mkdir -p /cow/mod /cow/buffer
    
    # Mount overlay
    log_msg "Mounting overlay filesystem"
    mount -t overlay overlay -o lowerdir=/squash,upperdir=/cow/mod,workdir=/cow/buffer /.root || {
        log_msg "ERROR: Failed to mount overlay!"
        log_msg "Check: lowerdir=/squash, upperdir=/cow/mod, workdir=/cow/buffer"
        problem
        return 1
    }
    log_msg "Overlay mounted at /.root"
    
    # Verify overlay is writable
    if ! touch /.root/test_write 2>/dev/null; then
        log_msg "ERROR: Overlay is not writable!"
        problem
        return 1
    fi
    rm -f /.root/test_write
    
    # Setup user files
    ensure_users
    
    # Create bind mount directories
    mkdir -p /.root/mnt/live /.root/mnt/changes /.root/mnt/container 2>/dev/null
    
    # Bind mount for persistence
    mount --bind /cow/mod /.root/mnt/changes 2>/dev/null || log_msg "Warning: Could not bind mount changes"
    mount --bind /mnt /.root/mnt/container 2>/dev/null || log_msg "Warning: Could not bind mount container"
    mount --bind /squash /.root/mnt/live 2>/dev/null || log_msg "Warning: Could not bind mount live"
    
    # Verify root filesystem
    verify_root_filesystem || return 1
    
    log_msg "Root filesystem prepared successfully!"
    return 0
}

# ===================== CLEANUP FUNCTIONS =====================

cleanup_udev() {
    log_msg "Stopping udev..."
    killall -w udevd 2>/dev/null || true
    killall -w systemd-udevd 2>/dev/null || true
}

# ===================== MAIN =====================

# Parse cmdline early
for param in $(cat /proc/cmdline 2>/dev/null || echo ""); do
    case $param in
        debug) DEBUG=true; set -x ;;
        rootdelay=*) rootdelay=${param#rootdelay=} ;;
    esac
done

log_msg "=== LeakOS Live ISO Init Starting ==="
log_msg "Debug mode: $DEBUG"

# Create essential directories
log_msg "Creating essential directories..."
mkdir -p /proc /sys /dev /run /tmp /dev/pts 2>/dev/null

# Mount pseudo-filesystems
log_msg "Mounting pseudo-filesystems..."

# Mount devtmpfs
mount -t devtmpfs devtmpfs /dev 2>/dev/null || {
    log_msg "devtmpfs failed, trying tmpfs"
    mount -t tmpfs tmpfs /dev
    mknod -m 622 /dev/console c 5 1 2>/dev/null
    mknod -m 666 /dev/null c 1 3 2>/dev/null
    mknod -m 666 /dev/zero c 1 5 2>/dev/null
    mknod -m 644 /dev/random c 1 8 2>/dev/null
    mknod -m 644 /dev/urandom c 1 9 2>/dev/null
}

# Mount proc (critical)
mount -t proc proc /proc || {
    log_msg "CRITICAL: proc mount failed!"
    problem
}

# Mount sysfs
mount -t sysfs sysfs /sys 2>/dev/null || log_msg "sysfs mount failed (non-fatal)"

# Mount tmpfs on /run
mount -t tmpfs tmpfs /run -o mode=755 2>/dev/null || log_msg "tmpfs /run failed (non-fatal)"

# Mount devpts
mount -t devpts devpts /dev/pts -o gid=5,mode=620 2>/dev/null || log_msg "devpts mount failed (non-fatal)"

# Verify /proc/cmdline exists
if [ ! -r /proc/cmdline ]; then
    log_msg "WARNING: /proc/cmdline missing - remounting /proc"
    umount /proc 2>/dev/null
    mount -t proc proc /proc || {
        log_msg "Cannot remount /proc!"
        problem
    }
fi

# Read cmdline safely
cmdline=$(cat /proc/cmdline 2>/dev/null || echo "")
log_msg "Kernel cmdline: $cmdline"

# Parse again for debug
for param in $cmdline; do
    case $param in
        debug) DEBUG=true; set -x ;;
    esac
done

# Start udev
log_msg "Starting udev..."
UDEVD=""

# Find udevd
for p in /sbin/udevd /usr/sbin/udevd /lib/udev/udevd /usr/lib/udev/udevd /sbin/systemd-udevd; do
    if [ -x "$p" ]; then
        UDEVD="$p"
        log_msg "Found udevd at $UDEVD"
        break
    fi
done

if [ -z "$UDEVD" ]; then
    log_msg "udevd not found, continuing without udev"
else
    # Start udevd
    $UDEVD --daemon --resolve-names=never 2>/dev/null || {
        log_msg "Failed to start udevd"
        UDEVD=""
    }
fi

# Trigger uevents if udev is running
if [ -n "$UDEVD" ]; then
    log_msg "Triggering uevents..."
    udevadm trigger --action=add 2>/dev/null || true
    udevadm settle --timeout=30 2>/dev/null || true
    log_msg "udev ready"
fi

# Apply rootdelay if specified
if [ -n "$rootdelay" ]; then
    log_msg "Waiting $rootdelay seconds (rootdelay)..."
    sleep "$rootdelay"
fi

# Mount root filesystem
log_msg "Setting up root filesystem..."
if ! do_mount_root; then
    log_msg "Failed to setup root filesystem!"
    problem
fi

# Cleanup udev
[ -n "$UDEVD" ] && cleanup_udev

# Create /dev/console in new root if needed
if [ ! -c "/.root/dev/console" ]; then
    mknod -m 622 /.root/dev/console c 5 1 2>/dev/null
fi

if [ ! -c "/.root/dev/null" ]; then
    mknod -m 666 /.root/dev/null c 1 3 2>/dev/null
fi

# Final debug
if [ "$DEBUG" = true ]; then
    log_msg "=== DEBUG: Pre-switchroot information ==="
    log_msg "Current directory: $(pwd)"
    log_msg "Init in new root:"
    ls -la /.root/sbin/init /.root/bin/init /.root/init 2>/dev/null | while read line; do log_msg "  $line"; done
    log_msg "Contents of /.root:"
    ls -la /.root/ | head -20 | while read line; do log_msg "  $line"; done
    log_msg "Mounts:"
    mount | while read line; do log_msg "  $line"; done
    
    # Drop to shell for debugging if requested
    if [ -f /tmp/debug_init ]; then
        log_msg "Debug shell before switch_root. Type 'exit' to continue."
        /bin/sh
    fi
fi

# Final check
if [ ! -x "/.root/sbin/init" ] && [ ! -x "/.root/bin/init" ]; then
    log_msg "FATAL: No init found before switch_root!"
    log_msg "Available executables in /.root:"
    find /.root -type f -executable 2>/dev/null | head -20 | while read line; do log_msg "  $line"; done
    problem
fi

# Switch to new root
log_msg "Switching to new root..."

# Try different switch_root syntaxes
if [ -x "/.root/sbin/init" ]; then
    exec switch_root /.root /sbin/init "$@"
elif [ -x "/.root/bin/init" ]; then
    exec switch_root /.root /bin/init "$@"
elif [ -x "/.root/init" ]; then
    exec switch_root /.root /init "$@"
else
    log_msg "FATAL: Cannot find init to execute!"
    problem
fi

# Fallback if exec fails
log_msg "FATAL: switch_root failed!"
log_msg "This should not happen if exec succeeded"
problem
